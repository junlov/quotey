# Quotey Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED: Slack Tokens
# =============================================================================
# Get these from https://api.slack.com/apps > Your App > OAuth & Permissions

# App-Level Token (starts with xapp-)
SLACK_APP_TOKEN=xapp-your-app-token-here

# Bot User OAuth Token (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# =============================================================================
# OPTIONAL: Database
# =============================================================================
# SQLite database URL (default: sqlite://quotey.db)
QUOTEY_DATABASE_URL=sqlite://quotey.db

# =============================================================================
# OPTIONAL: Logging
# =============================================================================
# Log level: trace, debug, info, warn, error (default: info)
QUOTEY_LOG_LEVEL=info

# Log format: compact, pretty, json (default: compact)
QUOTEY_LOG_FORMAT=compact

# =============================================================================
# OPTIONAL: LLM Configuration
# =============================================================================
# LLM provider: openai, anthropic, ollama (default: ollama)
LLM_PROVIDER=ollama

# OpenAI/Anthropic API key (required if using those providers)
# LLM_API_KEY=your-api-key

# Ollama base URL (default: http://localhost:11434)
# For Docker Compose, use: http://ollama:11434
LLM_BASE_URL=http://localhost:11434

# LLM model name (default: llama3.1)
# For Ollama: llama3.1, mistral, etc.
# For OpenAI: gpt-4o, gpt-4o-mini, etc.
LLM_MODEL=llama3.1

# =============================================================================
# OPTIONAL: Server
# =============================================================================
# Health check port (default: 8080)
HEALTH_CHECK_PORT=8080

# Bind address (default: 127.0.0.1)
QUOTEY_SERVER_BIND_ADDRESS=127.0.0.1

# =============================================================================
# OPTIONAL: Development
# =============================================================================
# Disable clippy in pre-commit hook for faster commits (default: enabled)
# Set to 1 to skip clippy checks during git commit
# QUOTEY_PRE_COMMIT_CLIPPY=0
